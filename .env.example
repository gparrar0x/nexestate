# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL from Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Anon (public) key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service role key — NEVER expose in browser, server-only
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ─── Site URL ────────────────────────────────────────────────────────────────
# Used for magic link redirect and OG metadata
# Local: http://localhost:3000
# Production: https://nexestate.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────────
# From Upstash console > Redis > REST API
UPSTASH_REDIS_REST_URL=https://<database-name>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-rest-token>

# ─── Vercel (analytics + speed insights) ─────────────────────────────────────
# Auto-injected in Vercel deployments; set manually for local dev if needed
# VERCEL_URL is injected by Vercel automatically
NEXT_PUBLIC_VERCEL_ENV=development

# ─── Encryption ──────────────────────────────────────────────────────────────
# AES-256-GCM key for API key storage — NEVER expose, server-only
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=  # 64-char hex string (32 bytes) for AES-256-GCM

# ─── Sentry ──────────────────────────────────────────────────────────────────
# DSN from Sentry project > Settings > Client Keys
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Auth token for source map upload in CI — from Sentry > Settings > Auth Tokens
# Scope: project:releases + org:read
SENTRY_AUTH_TOKEN=

# Sentry org slug and project slug (used by withSentryConfig in next.config.ts)
SENTRY_ORG=
SENTRY_PROJECT=
